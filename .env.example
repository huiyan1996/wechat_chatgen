MONGODB_URI=mongodb://127.0.0.1:27017/chatgen
JWT_SECRET=your-super-secret-jwt-key-change-this

# Netlify (Site settings → Environment variables):
# - MONGODB_URI — use a cloud URI (MongoDB Atlas), NOT localhost
# - JWT_SECRET — any long random string
# Scope both to "Functions" (or "All") so server routes can read them at runtime.
# In Atlas: Network Access → allow 0.0.0.0/0 (Netlify has no fixed IP).

# Cloudinary image upload (from scriptLive.js)
CLOUDINARY_CLOUD_NAME=dm8co83yz
CLOUDINARY_UPLOAD_PRESET=wecgen
